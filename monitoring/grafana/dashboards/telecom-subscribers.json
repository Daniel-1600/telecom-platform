          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(telecom_credit_balance < 10)",
          "interval": "",
          "legendFormat": "Low Balance Subscribers",
          "refId": "A"
        }
      ],
      "title": "Low Balance Alerts",
      "type": "stat"
    },
